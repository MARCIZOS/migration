"""
Example .env file for PDMS deployment
Copy this to .env and fill in your values
"""

# Groq API Key for LLM explanations
# Get your key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Backend API URL
# Local development:
# BACKEND_URL=http://127.0.0.1:8002/portfolio

# Production (update after deploying backend):
# BACKEND_URL=https://pdms-backend.onrender.com/portfolio

# Streamlit Configuration
STREAMLIT_SERVER_PORT=8600
STREAMLIT_SERVER_HEADLESS=true
